<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="vue.MedicamentController"
            style="-fx-background-color: #F5F6FA;">

    <VBox AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- HEADER VERT -->
        <HBox style="-fx-background-color: #1a7a4a; -fx-padding: 14 20 14 20;"
              spacing="12" alignment="CENTER_LEFT">
            <Label text="💊 Gestion de Pharmacie"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="— Système de gestion des médicaments"
                   style="-fx-text-fill: #a8e6c3; -fx-font-size: 12px;"/>
        </HBox>

        <VBox spacing="12" style="-fx-padding: 15;">

            <!-- CARTES STATISTIQUES -->
            <HBox spacing="10">
                <VBox style="-fx-background-color: #e8f5ee;
                             -fx-padding: 10 14 10 14;
                             -fx-background-radius: 8;" spacing="4">
                    <Label text="Total médicaments"
                           style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                    <Label fx:id="lblTotal"
                           text="0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>
                </VBox>
                <VBox style="-fx-background-color: #e8f5ee;
                             -fx-padding: 10 14 10 14;
                             -fx-background-radius: 8;" spacing="4">
                    <Label text="Disponibles"
                           style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                    <Label fx:id="lblDisponibles"
                           text="0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>
                </VBox>
                <VBox style="-fx-background-color: #fdecea;
                             -fx-padding: 10 14 10 14;
                             -fx-background-radius: 8;" spacing="4">
                    <Label text="Non disponibles"
                           style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                    <Label fx:id="lblNonDisponibles"
                           text="0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #c0392b;"/>
                </VBox>
            </HBox>

            <!-- FORMULAIRE -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding: 14;
                         -fx-border-color: #E0E0E0;
                         -fx-border-radius: 8;
                         -fx-background-radius: 8;">

                <Label text="✦ Informations du médicament"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>

                <HBox spacing="12">
                    <VBox spacing="4">
                        <Label text="Code" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                        <TextField fx:id="txtCode" promptText="Ex: MED001"
                                   style="-fx-pref-width: 120; -fx-padding: 6;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Nom" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                        <TextField fx:id="txtNom" promptText="Ex: Doliprane"
                                   style="-fx-pref-width: 160; -fx-padding: 6;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Type" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                        <ComboBox fx:id="cmbType" promptText="Choisir..."
                                  style="-fx-pref-width: 150;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Quantité" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                        <TextField fx:id="txtQuantite" promptText="Ex: 100"
                                   style="-fx-pref-width: 90; -fx-padding: 6;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Date expiration" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                        <DatePicker fx:id="datePicker" style="-fx-pref-width: 150;"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Disponible" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                        <CheckBox fx:id="chkDisponible" style="-fx-padding: 6;"/>
                    </VBox>
                </HBox>

                <!-- BOUTONS -->
                <HBox spacing="8">
                    <Button text="✚ Ajouter" onAction="#ajouter"
                            style="-fx-background-color: #1a7a4a;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 14;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>
                    <Button text="✎ Modifier" onAction="#modifier"
                            style="-fx-background-color: #2d6a9f;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 14;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>
                    <Button text="✖ Supprimer" onAction="#supprimer"
                            style="-fx-background-color: #c0392b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 14;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>
                    <Button text="↺ Actualiser" onAction="#actualiser"
                            style="-fx-background-color: #95a5a6;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-padding: 8 14;
                                   -fx-background-radius: 6;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- RECHERCHE + TABLEAU -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding: 14;
                         -fx-border-color: #E0E0E0;
                         -fx-border-radius: 8;
                         -fx-background-radius: 8;">

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="🔍 Recherche :"
                           style="-fx-font-weight: bold; -fx-text-fill: #1a7a4a;"/>
                    <TextField fx:id="txtRecherche"
                               promptText="Rechercher par nom ou type..."
                               onKeyReleased="#rechercher"
                               style="-fx-pref-width: 280; -fx-padding: 6;"/>
                </HBox>

                <TableView fx:id="tableMedicaments" prefHeight="280"
                           style="-fx-border-color: #E0E0E0;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="45"/>
                        <TableColumn fx:id="colCode" text="Code" prefWidth="90"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                        <TableColumn fx:id="colQuantite" text="Quantité" prefWidth="80"/>
                        <TableColumn fx:id="colDateExpiration" text="Date Exp." prefWidth="110"/>
                        <TableColumn fx:id="colDisponible" text="Disponible" prefWidth="90"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>